      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (container) (count_over_time({container=~\"$container\"} |~ \"ERROR|WARNING|CRITICAL\" [$__interval]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Wszystkie logi",
      "description": "Logi z wybranych kontenerów. Użyj zmiennych powyżej do filtrowania po kontenerze, poziomie i szukanej frazie.",
