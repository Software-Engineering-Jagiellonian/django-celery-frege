  "panels": [
    {
      "id": 1,
      "title": "Wolumen logów w czasie",
      "description": "Liczba linii logów na kontener w wybranym oknie czasowym.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 1 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (container) (count_over_time({container=~\"$container\"} |~ \"$level\" |~ \"$search\" [$__interval]))",
          "legendFormat": "{{container}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Błędy i ostrzeżenia w czasie",
      "description": "Liczba linii zawierających ERROR lub WARNING na kontener.",
